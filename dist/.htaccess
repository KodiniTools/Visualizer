# Correct MIME types for JS modules and workers
AddType application/javascript .js .mjs
AddType application/json .json
AddType font/woff2 .woff2

# Enable mod_rewrite for SPA routing
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /visualizer/

  # Serve existing files and directories directly (do NOT rewrite them)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # For everything else: SPA fallback to index.html
  RewriteRule ^ index.html [L]
</IfModule>
